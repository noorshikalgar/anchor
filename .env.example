# Copy to .env and fill in values. Never commit .env.

# Postgres (used by docker-compose)
POSTGRES_PASSWORD=change_this_strong_password

# Backend
NODE_ENV=production
PORT=3001
DATABASE_URL=postgres://anchor:change_this_strong_password@postgres:5432/anchor

# Auth — generate with: openssl rand -hex 32
JWT_SECRET=replace_with_64_char_random_hex

# Encryption key for stored API keys — generate with: openssl rand -hex 32
ENCRYPTION_KEY=replace_with_64_char_random_hex

# CORS origin (frontend URL in production)
CORS_ORIGIN=http://localhost:5173
