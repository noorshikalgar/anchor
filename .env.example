# Copy to .env and fill in values. Never commit .env.

# Backend
NODE_ENV=production
PORT=3001
DATABASE_PATH=./data/anchor.db

# Auth (generate with: openssl rand -hex 32)
JWT_SECRET=replace_with_random_secret_64_chars
JWT_EXPIRES_IN=30d

# Encryption key for stored API keys (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=replace_with_random_secret_64_chars
