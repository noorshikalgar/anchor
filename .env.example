# Copy to .env and fill in values. Never commit .env.

# Postgres (used by docker-compose)
POSTGRES_PASSWORD=change_this_strong_password

# Host port for the web UI — change if 3000 taken on your server
FRONTEND_PORT=3000

# Backend
NODE_ENV=production
PORT=3001
DATABASE_URL=postgres://anchor:change_this_strong_password@postgres:5432/anchor

# Auth — generate with: openssl rand -hex 32
JWT_SECRET=replace_with_64_char_random_hex

# Encryption key for stored API keys — generate with: openssl rand -hex 32
ENCRYPTION_KEY=replace_with_64_char_random_hex

# CORS origin — set to your domain in production (e.g. https://anchor.yourdomain.com)
CORS_ORIGIN=http://localhost:5173

# Admin key for family password resets — generate with: openssl rand -hex 16
ADMIN_RESET_KEY=replace_with_random_hex

# Web push (VAPID) — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=replace_with_vapid_public_key
VAPID_PRIVATE_KEY=replace_with_vapid_private_key
VAPID_SUBJECT=mailto:you@example.com

# Timezone for day boundaries and the evening reminder cron (24h hour)
TZ=Asia/Kolkata
REMINDER_HOUR=20
